{
  "tasks": {
    "dev": "deno run -A --watch main.js",
    "test": "deno test -A",
    "test:watch": "deno test -A --watch",
    "coverage": "deno test -A --coverage",
    "setup": "chmod u+x ./setup.sh && ./setup.sh",
    "coverage:detailed": {
      "command": "deno coverage --detailed",
      "dependencies": ["coverage"]
    },
    "serve-static": "serve public"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "hono": "npm:hono@^4.12.9"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"]
  }
}
